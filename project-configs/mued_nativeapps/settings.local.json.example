{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git worktree:*)",
      "Bash(git blame:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh api:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "mcp__claude-peers__send_message",
      "mcp__claude-peers__set_summary",
      "mcp__claude-peers__list_peers",
      "mcp__claude-peers__check_messages",
      "Bash(npx expo prebuild:*)",
      "Bash(npx expo start:*)",
      "Bash(npx expo run:ios:*)",
      "Bash(npx expo run:android:*)",
      "Bash(npx expo install:*)",
      "Bash(npm install:*)",
      "Bash(npm run test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm audit:*)",
      "Bash(xcodebuild:*)",
      "Bash(pod install:*)",
      "Bash(sips:*)",
      "Bash(patch-package:*)",
      "Bash(npx ts-node:*)",
      "Bash(rm -rf ios/:*)",
      "Bash(rm -rf android/:*)",
      "Bash(rm -rf .expo/:*)",
      "Bash(rm -rf DerivedData:*)",
      "Bash(xcrun simctl:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kimny/Dropbox/_DevProjects/mued/mued_v2/apps/.claude/hooks/block-main-push.sh"
          }
        ]
      }
    ]
  }
}

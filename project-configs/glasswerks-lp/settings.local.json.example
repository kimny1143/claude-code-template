{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git worktree:*)",
      "Bash(git blame:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh api:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "mcp__claude-peers__send_message",
      "mcp__claude-peers__set_summary",
      "mcp__claude-peers__list_peers",
      "mcp__claude-peers__check_messages",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run preview:*)",
      "Bash(npm run fetch-works:*)",
      "Bash(node scripts/fetch-works.mjs:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vite:*)",
      "Bash(vercel:*)",
      "Bash(npx playwright:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/glasswerks-lp/.claude/hooks/block-main-push.sh"
          }
        ]
      }
    ]
  }
}

{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git worktree:*)",
      "Bash(git blame:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh api:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "mcp__claude-peers__send_message",
      "mcp__claude-peers__set_summary",
      "mcp__claude-peers__list_peers",
      "mcp__claude-peers__check_messages",
      "Bash(npx freee-mcp:*)",

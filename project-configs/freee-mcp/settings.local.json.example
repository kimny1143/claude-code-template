  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kimny/Dropbox/_DevProjects/freee-MCP/.claude/hooks/block-main-push.sh"
          }
        ]
      }
    ]
  }
